# scrapedatshi-mcp environment variables
#
# Copy this file to .env for local development, or add these keys
# directly to the "env" block in your claude_desktop_config.json.
#
# Keys set here are resolved automatically by the MCP server —
# you won't need to type them into Claude's chat window.

# ── scrapedatshi (required) ───────────────────────────────────────────────────
# Get your key at: https://scrapedatshi.com/portal
SCRAPEDATSHI_API_KEY=sds_your_key_here

# ── LLM providers ─────────────────────────────────────────────────────────────
# Used for: extract_data, extract_crawl, and contextual_retrieval in scrape/crawl/sync
# Only set the key(s) for the provider(s) you use.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Embedding providers ───────────────────────────────────────────────────────
# Used for: sync_to_vectordb
# Only set the key(s) for the provider(s) you use.
# Note: OPENAI_API_KEY above also covers OpenAI embeddings.

COHERE_API_KEY=
MISTRAL_API_KEY=
VOYAGE_API_KEY=

# ── Vector database providers ─────────────────────────────────────────────────
# Used for: sync_to_vectordb
# API keys are injected automatically into vector_db_config when set here.
# Connection strings, index hosts, and collection names must still be
# provided as tool arguments (they are not secret and vary per request).

PINECONE_API_KEY=pc-...
QDRANT_API_KEY=          # optional — not required for local Qdrant instances
WEAVIATE_API_KEY=        # optional — not required for local Weaviate instances
